APP_NAME=Incremental RAG Indexing Platform
APP_ENVIRONMENT=local
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5432/rag_indexing
SEED_DOCUMENTS_PATH=seed_documents# LLM provider configuration
LLM_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=800
OPENAI_INPUT_PRICE_PER_1M_TOKENS_USD=0.75
OPENAI_OUTPUT_PRICE_PER_1M_TOKENS_USD=4.50
